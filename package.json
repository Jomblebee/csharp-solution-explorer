{
  "name": "jomblebee-csharp-solution-explorer",
  "displayName": "C# Solution Explorer",
  "description": "A lightweight Solution Explorer for C# projects in VS Code (and Open VSX-compatible editors).",
  "version": "0.7.0",
  "publisher": "jomblebee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jomblebee/csharp-solution-explorer"
  },
  "bugs": {
    "url": "https://github.com/Jomblebee/csharp-solution-explorer/issues"
  },
  "homepage": "https://github.com/Jomblebee/csharp-solution-explorer#readme",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "csharp",
    "solution explorer",
    "dotnet",
    "sln",
    "slnx"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": [
      {
        "id": "csharpSolutionExplorer",
        "title": "C# Solution Explorer",
        "properties": {
          "csharpSolutionExplorer.confirmMove": {
            "type": "boolean",
            "default": true,
            "description": "Ask for confirmation before moving items in the Solution Explorer."
          },
          "csharpSolutionExplorer.nuget.checkForUpdates": {
            "type": "boolean",
            "default": true,
            "description": "Check nuget.org for newer versions of direct packages and flag outdated ones in the Dependencies tree."
          }
        }
      },
      {
        "id": "csharpSolutionExplorer.templates",
        "title": "Templates",
        "order": 1,
        "properties": {
          "csharpSolutionExplorer.templates.class": {
            "type": "string",
            "default": "namespace ${namespace};\n\npublic class ${name}\n{\n    ${cursor}\n}\n",
            "description": "Template for new C# class files. Variables: ${namespace}, ${name}, ${filename}, ${date}, ${cursor} (sets initial cursor position). Clear to show an error instead of creating the file."
          },
          "csharpSolutionExplorer.templates.interface": {
            "type": "string",
            "default": "namespace ${namespace};\n\npublic interface ${name}\n{\n    ${cursor}\n}\n",
            "description": "Template for new C# interface files. Variables: ${namespace}, ${name}, ${filename}, ${date}, ${cursor} (sets initial cursor position). Clear to show an error instead of creating the file."
          },
          "csharpSolutionExplorer.templates.record": {
            "type": "string",
            "default": "namespace ${namespace};\n\npublic record ${name}(${cursor});\n",
            "description": "Template for new C# record files. Variables: ${namespace}, ${name}, ${filename}, ${date}, ${cursor} (sets initial cursor position). Clear to show an error instead of creating the file."
          },
          "csharpSolutionExplorer.templates.enum": {
            "type": "string",
            "default": "namespace ${namespace};\n\npublic enum ${name}\n{\n    ${cursor}\n}\n",
            "description": "Template for new C# enum files. Variables: ${namespace}, ${name}, ${filename}, ${date}, ${cursor} (sets initial cursor position). Clear to show an error instead of creating the file."
          },
          "csharpSolutionExplorer.templates.struct": {
            "type": "string",
            "default": "namespace ${namespace};\n\npublic struct ${name}\n{\n    ${cursor}\n}\n",
            "description": "Template for new C# struct files. Variables: ${namespace}, ${name}, ${filename}, ${date}, ${cursor} (sets initial cursor position). Clear to show an error instead of creating the file."
          },
          "csharpSolutionExplorer.templates.razor": {
            "type": "string",
            "default": "@namespace ${namespace}\n\n<h3>${name}</h3>\n\n@code {\n    ${cursor}\n}\n",
            "description": "Template for new Razor component files (.razor). Variables: ${namespace}, ${name}, ${filename}, ${date}, ${cursor} (sets initial cursor position). Clear to show an error instead of creating the file."
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "csharp-solution-explorer-activitybar",
          "title": "C# Solution Explorer",
          "icon": "resources/solution-explorer-icon.svg"
        }
      ]
    },
    "views": {
      "csharp-solution-explorer-activitybar": [
        {
          "id": "csharpSolutionExplorer.view",
          "name": "Solution Explorer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "csharpSolutionExplorer.view",
        "contents": "No .sln file was found in this workspace.\n[Open Folder](command:vscode.openFolder)\nIf you have a solution file, open the folder that contains it."
      }
    ],
    "commands": [
      {
        "command": "csharpSolutionExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.openFile",
        "title": "Open File",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newClass",
        "title": "New Class...",
        "icon": "$(symbol-class)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newInterface",
        "title": "New Interface...",
        "icon": "$(symbol-interface)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newRecord",
        "title": "New Record...",
        "icon": "$(symbol-struct)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newEnum",
        "title": "New Enum...",
        "icon": "$(symbol-enum)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newStruct",
        "title": "New Struct...",
        "icon": "$(symbol-struct)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newRazor",
        "title": "New Razor Component...",
        "icon": "$(file-code)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newFile",
        "title": "New File...",
        "icon": "$(new-file)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newFolder",
        "title": "New Folder...",
        "icon": "$(new-folder)",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newSolutionFolder",
        "title": "New Solution Folder...",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.rename",
        "title": "Rename...",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.delete",
        "title": "Delete",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.addExistingProject",
        "title": "Add Existing Project...",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.removeProjectFromSolution",
        "title": "Remove from Solution",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.addProjectReference",
        "title": "Add Project Reference...",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.removeProjectReference",
        "title": "Remove",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.addPackageReference",
        "title": "Add Package...",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.updatePackageReference",
        "title": "Update Package...",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.updatePackageToLatest",
        "title": "Update to Latest Version",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.removePackageReference",
        "title": "Remove Package",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.restore",
        "title": "Restore",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.clean",
        "title": "Clean",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.buildProject",
        "title": "Build",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.rebuild",
        "title": "Rebuild",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.test",
        "title": "Test",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.runProject",
        "title": "Run Project",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.newProject",
        "title": "New Project...",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.openSolutionFile",
        "title": "Open in Editor",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.openProjectFile",
        "title": "Open in Editor",
        "category": "C# Solution Explorer"
      },
      {
        "command": "csharpSolutionExplorer.openSettings",
        "title": "Settings",
        "icon": "$(gear)",
        "category": "C# Solution Explorer"
      }
    ],
    "submenus": [
      {
        "id": "csharpSolutionExplorer.newItem",
        "label": "New Item",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "csharpSolutionExplorer.refresh",
          "when": "view == csharpSolutionExplorer.view",
          "group": "navigation"
        },
        {
          "command": "csharpSolutionExplorer.openSettings",
          "when": "view == csharpSolutionExplorer.view",
          "group": "navigation@99"
        }
      ],
      "csharpSolutionExplorer.newItem": [
        {
          "command": "csharpSolutionExplorer.newClass",
          "group": "1_cs"
        },
        {
          "command": "csharpSolutionExplorer.newInterface",
          "group": "1_cs"
        },
        {
          "command": "csharpSolutionExplorer.newRecord",
          "group": "1_cs"
        },
        {
          "command": "csharpSolutionExplorer.newEnum",
          "group": "1_cs"
        },
        {
          "command": "csharpSolutionExplorer.newStruct",
          "group": "1_cs"
        },
        {
          "command": "csharpSolutionExplorer.newRazor",
          "group": "2_web"
        },
        {
          "command": "csharpSolutionExplorer.newFile",
          "group": "8_generic"
        },
        {
          "command": "csharpSolutionExplorer.newFolder",
          "group": "9_folder"
        }
      ],
      "view/item/context": [
        {
          "submenu": "csharpSolutionExplorer.newItem",
          "when": "view == csharpSolutionExplorer.view && (viewItem == csharpSolutionExplorer.folder || viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/)",
          "group": "1_new"
        },
        {
          "command": "csharpSolutionExplorer.newSolutionFolder",
          "when": "view == csharpSolutionExplorer.view && (viewItem == csharpSolutionExplorer.solution || viewItem == csharpSolutionExplorer.solutionFolder)",
          "group": "1_new"
        },
        {
          "command": "csharpSolutionExplorer.newProject",
          "when": "view == csharpSolutionExplorer.view && (viewItem == csharpSolutionExplorer.solution || viewItem == csharpSolutionExplorer.solutionFolder)",
          "group": "1_new"
        },
        {
          "command": "csharpSolutionExplorer.addExistingProject",
          "when": "view == csharpSolutionExplorer.view && (viewItem == csharpSolutionExplorer.solution || viewItem == csharpSolutionExplorer.solutionFolder)",
          "group": "1_new"
        },
        {
          "command": "csharpSolutionExplorer.addProjectReference",
          "when": "view == csharpSolutionExplorer.view && (viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.dependencies || viewItem == csharpSolutionExplorer.dependencyCategory.projects)",
          "group": "1_new"
        },
        {
          "command": "csharpSolutionExplorer.removeProjectReference",
          "when": "view == csharpSolutionExplorer.view && viewItem == csharpSolutionExplorer.projectReference",
          "group": "7_modification"
        },
        {
          "command": "csharpSolutionExplorer.addPackageReference",
          "when": "view == csharpSolutionExplorer.view && (viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.dependencies || viewItem == csharpSolutionExplorer.dependencyCategory.packages)",
          "group": "1_new"
        },
        {
          "command": "csharpSolutionExplorer.updatePackageToLatest",
          "when": "view == csharpSolutionExplorer.view && viewItem == csharpSolutionExplorer.packageReference.outdated",
          "group": "7_modification@1"
        },
        {
          "command": "csharpSolutionExplorer.updatePackageReference",
          "when": "view == csharpSolutionExplorer.view && viewItem =~ /^csharpSolutionExplorer\\.packageReference(\\.outdated)?$/",
          "group": "7_modification@2"
        },
        {
          "command": "csharpSolutionExplorer.removePackageReference",
          "when": "view == csharpSolutionExplorer.view && viewItem =~ /^csharpSolutionExplorer\\.packageReference(\\.outdated)?$/",
          "group": "7_modification@3"
        },
        {
          "command": "csharpSolutionExplorer.buildProject",
          "when": "view == csharpSolutionExplorer.view && (viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.solution)",
          "group": "2_build@1"
        },
        {
          "command": "csharpSolutionExplorer.rebuild",
          "when": "view == csharpSolutionExplorer.view && (viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.solution)",
          "group": "2_build@2"
        },
        {
          "command": "csharpSolutionExplorer.runProject",
          "when": "view == csharpSolutionExplorer.view && viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/",
          "group": "2_build@3"
        },
        {
          "command": "csharpSolutionExplorer.test",
          "when": "view == csharpSolutionExplorer.view && (viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.solution)",
          "group": "2_build@4"
        },
        {
          "command": "csharpSolutionExplorer.restore",
          "when": "view == csharpSolutionExplorer.view && (viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.solution)",
          "group": "2_build@5"
        },
        {
          "command": "csharpSolutionExplorer.clean",
          "when": "view == csharpSolutionExplorer.view && (viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.solution)",
          "group": "2_build@6"
        },
        {
          "command": "csharpSolutionExplorer.rename",
          "when": "view == csharpSolutionExplorer.view && (viewItem == csharpSolutionExplorer.folder || viewItem == csharpSolutionExplorer.file || viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.solutionFolder)",
          "group": "7_modification"
        },
        {
          "command": "csharpSolutionExplorer.delete",
          "when": "view == csharpSolutionExplorer.view && (viewItem == csharpSolutionExplorer.folder || viewItem == csharpSolutionExplorer.file || viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/ || viewItem == csharpSolutionExplorer.solutionFolder)",
          "group": "7_modification"
        },
        {
          "command": "csharpSolutionExplorer.removeProjectFromSolution",
          "when": "view == csharpSolutionExplorer.view && viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/",
          "group": "7_modification"
        },
        {
          "command": "csharpSolutionExplorer.openSolutionFile",
          "when": "view == csharpSolutionExplorer.view && viewItem == csharpSolutionExplorer.solution",
          "group": "0_open"
        },
        {
          "command": "csharpSolutionExplorer.openProjectFile",
          "when": "view == csharpSolutionExplorer.view && viewItem =~ /^csharpSolutionExplorer\\.project(\\.nested)?$/",
          "group": "0_open"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
